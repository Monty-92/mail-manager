# mail-manager — Environment Configuration
# Copy to .env and fill in your values

# ─── PostgreSQL ───
POSTGRES_USER=mailmanager
POSTGRES_PASSWORD=mailmanager_dev
POSTGRES_DB=mailmanager
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mailmanager:mailmanager_dev@postgres:5432/mailmanager

# ─── Redis ───
REDIS_URL=redis://redis:6379/0

# ─── Ollama ───
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Gmail API (OAuth 2.0) ───
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Google Tasks API ───
# Uses same OAuth credentials as Gmail

# ─── Microsoft 365 (Personal Account) ───
# Register app at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common

# ─── Service Ports ───
INGESTION_PORT=8001
PREPROCESSING_PORT=8002
LLM_ANALYSIS_PORT=8003
TOPIC_TRACKING_PORT=8004
SUMMARY_GENERATION_PORT=8005
TASK_MANAGEMENT_PORT=8006
CALENDAR_SYNC_PORT=8007
BFF_PORT=8000

# ─── Frontend ───
VITE_API_BASE_URL=http://localhost:8000/api/v1
